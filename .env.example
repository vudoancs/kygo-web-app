# Public (exposed to browser — never put secrets here)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL tới kygo-erp-api (gồm prefix /api/v1). Trùng PORT trong kygo-erp-api/.env (mặc định 5001, không phải 50001).
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Server-only (optional BFF / server actions calling Nest)
# API_SERVER_URL=http://nestjs:4000/api
